# ─── Application ───────────────────────────────────────────
APP_NAME=Servify
APP_ENV=development          # development | staging | production
DEBUG=true
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
AUTO_CREATE_TABLES=true

# ─── Database (PostgreSQL) ──────────────────────────────────
DATABASE_URL=postgresql://servify:servify_pass@localhost:5432/servify_db
TEST_DATABASE_URL=postgresql://servify:servify_pass@localhost:5432/servify_test

# ─── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ───────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Email Tokens ──────────────────────────────────────────
EMAIL_SECRET_KEY=another-secret-for-email-tokens-change-in-production

# ─── Email (SMTP) ──────────────────────────────────────────
MAIL_USERNAME=noreply@servify.com
MAIL_PASSWORD=your_smtp_password
MAIL_FROM=noreply@servify.com
MAIL_FROM_NAME=Servify
MAIL_PORT=1025              # MailHog dev port | 587 for production TLS
MAIL_SERVER=localhost        # mailhog | smtp.sendgrid.net
MAIL_STARTTLS=false          # true for production
MAIL_SSL_TLS=false

# ─── OAuth (Google) ────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── File Storage ──────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# ─── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
AUTH_RATE_LIMIT_PER_MINUTE=5

# ─── Platform Config ───────────────────────────────────────
PLATFORM_FEE=49             # flat rupee fee per booking
DEFAULT_COMMISSION_RATE=0.20 # 20% commission
GST_RATE=0.18               # 18% GST
